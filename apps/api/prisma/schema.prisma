generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DATABASE_MIGRATE_URL")
  extensions = [pg_trgm, pgcrypto]
}

enum Role {
  PAIR_ADMIN
  CLIENT_EDITOR
  CLIENT_VIEWER
  API_CONSUMER
}

enum EntryStatus {
  draft
  scheduled
  active
  expired
  archived
}

enum SuggestionType {
  missing
  stale
  translation_gap
  consistency
  low_served
}

enum SuggestionStatus {
  open
  resolved
  dismissed
}

enum ScheduledJobAction {
  publish
  expire
}

enum ScheduledJobStatus {
  pending
  done
  failed
}

model Tenant {
  id                  String   @id @default(uuid()) @db.Uuid
  name                String
  slug                String   @unique
  logoUrl             String?  @map("logo_url")
  primaryColor        String?  @map("primary_color")
  faviconUrl          String?  @map("favicon_url")
  weeklyReportEmail   String?  @map("weekly_report_email")
  timezone            String   @default("Asia/Kuwait")
  createdAt           DateTime @default(now()) @map("created_at")

  users               User[]
  modules             Module[]
  entries             Entry[]
  media               Media[]
  apiKeys             ApiKey[]
  auditLog            AuditLog[]
  permissions         Permission[]
  chatSessions        ChatSession[]
  aiSuggestions       AiSuggestion[]
  scheduledJobs       ScheduledJob[]
  activityFeed        ActivityFeedEvent[]
  importLogs          ImportLog[]
  contentAnalytics    ContentAnalyticsEvent[]

  @@map("tenants")
}

model User {
  id                    String   @id @default(uuid()) @db.Uuid
  tenantId              String   @map("tenant_id") @db.Uuid
  email                 String
  passwordHash          String   @map("password_hash")
  role                  Role
  name                  String
  lastLogin             DateTime? @map("last_login")
  walkthroughCompleted  Boolean  @default(false) @map("walkthrough_completed")
  createdAt             DateTime @default(now()) @map("created_at")

  tenant                Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  permissions           Permission[]
  chatSessions          ChatSession[]
  auditLog              AuditLog[]
  activityFeed          ActivityFeedEvent[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("users")
}

model Module {
  id                String   @id @default(uuid()) @db.Uuid
  tenantId          String   @map("tenant_id") @db.Uuid
  slug              String
  label             String
  icon              String?
  fieldDefinitions  Json     @map("field_definitions")
  behaviors         Json     @default("{}")
  isActive          Boolean  @default(true) @map("is_active")
  createdAt         DateTime @default(now()) @map("created_at")

  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  entries           Entry[]
  permissions       Permission[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("modules")
}

model Entry {
  id            String        @id @default(uuid()) @db.Uuid
  tenantId      String        @map("tenant_id") @db.Uuid
  moduleId      String        @map("module_id") @db.Uuid
  data          Json
  status        EntryStatus   @default(draft)
  mediaIds      String[]      @map("media_ids") @db.Uuid
  publishAt     DateTime?     @map("publish_at")
  expiresAt     DateTime?     @map("expires_at")
  externalId    String?       @map("external_id")
  createdBy     String?       @map("created_by") @db.Uuid
  updatedAt     DateTime      @updatedAt @map("updated_at")
  createdAt     DateTime      @default(now()) @map("created_at")

  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  module        Module        @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  versions      EntryVersion[]
  analytics     ContentAnalyticsEvent[]
  scheduledJobs ScheduledJob[]

  @@unique([tenantId, moduleId, externalId])
  @@index([tenantId, moduleId, status, updatedAt(sort: Desc)])
  @@index([tenantId, publishAt])
  @@index([tenantId, expiresAt])
  @@map("entries")
}

model EntryVersion {
  id             String   @id @default(uuid()) @db.Uuid
  entryId        String   @map("entry_id") @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  versionNumber  Int      @map("version_number")
  dataSnapshot   Json     @map("data_snapshot")
  changedBy      String?  @map("changed_by") @db.Uuid
  changedAt      DateTime @default(now()) @map("changed_at")
  changeSummary  String?  @map("change_summary")

  entry          Entry    @relation(fields: [entryId], references: [id], onDelete: Cascade)

  @@unique([entryId, versionNumber])
  @@index([tenantId])
  @@map("entry_versions")
}

model Media {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  filename     String
  mimeType     String   @map("mime_type")
  r2Key        String   @map("r2_key")
  sizeBytes    Int      @map("size_bytes")
  uploadedBy   String?  @map("uploaded_by") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at")

  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("media")
}

model ChatSession {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  messages      Json     @default("[]")
  summary       String?
  startedAt     DateTime @default(now()) @map("started_at")
  lastActiveAt  DateTime @default(now()) @map("last_active_at")

  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  voiceTranscripts VoiceTranscript[]

  @@index([tenantId, userId, lastActiveAt(sort: Desc)])
  @@map("chat_sessions")
}

model VoiceTranscript {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  chatSessionId  String   @map("chat_session_id") @db.Uuid
  audioR2Key     String   @map("audio_r2_key")
  transcriptText String   @map("transcript_text")
  durationMs     Int      @map("duration_ms")
  createdAt      DateTime @default(now()) @map("created_at")

  session        ChatSession @relation(fields: [chatSessionId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("voice_transcripts")
}

model ApiKey {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  keyHash     String   @unique @map("key_hash")
  keyPrefix   String   @map("key_prefix")
  label       String
  scopes      String[]
  expiresAt   DateTime? @map("expires_at")
  revokedAt   DateTime? @map("revoked_at")
  lastUsedAt  DateTime? @map("last_used_at")
  createdAt   DateTime @default(now()) @map("created_at")

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("api_keys")
}

model AuditLog {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  userId      String?  @map("user_id") @db.Uuid
  action      String
  entityType  String   @map("entity_type")
  entityId    String?  @map("entity_id")
  diff        Json?
  timestamp   DateTime @default(now())

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId, timestamp(sort: Desc)])
  @@map("audit_log")
}

model Permission {
  id          String  @id @default(uuid()) @db.Uuid
  tenantId    String  @map("tenant_id") @db.Uuid
  userId      String  @map("user_id") @db.Uuid
  moduleId    String  @map("module_id") @db.Uuid
  canRead     Boolean @default(true) @map("can_read")
  canWrite    Boolean @default(false) @map("can_write")
  canDelete   Boolean @default(false) @map("can_delete")
  canPublish  Boolean @default(false) @map("can_publish")

  tenant      Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  module      Module  @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([userId, moduleId])
  @@index([tenantId])
  @@map("permissions")
}

model ContentAnalyticsEvent {
  id                 String   @id @default(uuid()) @db.Uuid
  tenantId           String   @map("tenant_id") @db.Uuid
  moduleId           String?  @map("module_id") @db.Uuid
  entryId            String?  @map("entry_id") @db.Uuid
  eventType          String   @map("event_type")
  botConversationId  String?  @map("bot_conversation_id")
  timestamp          DateTime @default(now())

  tenant             Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  entry              Entry?   @relation(fields: [entryId], references: [id], onDelete: SetNull)

  @@index([tenantId, entryId, timestamp])
  @@map("content_analytics")
}

model AiSuggestion {
  id          String           @id @default(uuid()) @db.Uuid
  tenantId    String           @map("tenant_id") @db.Uuid
  type        SuggestionType
  moduleId    String?          @map("module_id") @db.Uuid
  description String
  status      SuggestionStatus @default(open)
  createdAt   DateTime         @default(now()) @map("created_at")

  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
  @@map("ai_suggestions")
}

model ScheduledJob {
  id           String             @id @default(uuid()) @db.Uuid
  tenantId     String             @map("tenant_id") @db.Uuid
  entryId      String             @map("entry_id") @db.Uuid
  action       ScheduledJobAction
  scheduledAt  DateTime           @map("scheduled_at")
  executedAt   DateTime?          @map("executed_at")
  status       ScheduledJobStatus @default(pending)

  tenant       Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  entry        Entry              @relation(fields: [entryId], references: [id], onDelete: Cascade)

  @@index([status, scheduledAt])
  @@map("scheduled_jobs")
}

model ActivityFeedEvent {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  userId       String?  @map("user_id") @db.Uuid
  action       String
  moduleSlug   String?  @map("module_slug")
  entryTitle   String?  @map("entry_title")
  detail       String?
  timestamp    DateTime @default(now())

  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId, timestamp(sort: Desc)])
  @@map("activity_feed")
}

model ImportLog {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  filename      String
  moduleId      String?  @map("module_id") @db.Uuid
  rowsImported  Int      @map("rows_imported")
  rowsFailed    Int      @map("rows_failed")
  errors        Json     @default("[]")
  createdAt     DateTime @default(now()) @map("created_at")

  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("import_logs")
}

model MigrationDiff {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  source      String
  expected    Json
  actual      Json
  diff        Json
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([tenantId, createdAt])
  @@map("migration_diffs")
}
